# Copie para .env.local e preencha com os dados do projeto Supabase.
#
# ATENCAO: tudo que comeca com VITE_ e embutido no bundle e fica PUBLICO.
# Nunca coloque a service_role key aqui -- ela bypassa toda a RLS.
# Apenas a publishable (anon) key entra no frontend.

VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_publishable_key_aqui
